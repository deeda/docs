{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "deeda",
  "description": "deeda Think developer documentation — the multi-provider agent harness, Cadence, and workflow markdown.",
  "colors": {
    "primary": "#3b82f6",
    "light": "#5ea0ff",
    "dark": "#2563eb"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "dark": "#0b1220"
    }
  },
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": ["index", "start-here", "quickstart", "agents"]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/tools-and-mcp",
          "concepts/hooks",
          "concepts/state-and-sessions",
          "concepts/thinking",
          "concepts/structured-output",
          "concepts/voice-and-realtime",
          "concepts/computer-use",
          "concepts/cost-batch-cache"
        ]
      },
      {
        "group": "Agent Harness",
        "pages": [
          "harness/overview",
          "harness/cadence",
          "harness/workflow-markdown",
          "harness/workflow-schema",
          "harness/template-variables",
          "harness/cookbook",
          "harness/snippets",
          "harness/runtimes",
          "harness/capabilities"
        ]
      },
      {
        "group": "Provider Capabilities",
        "pages": [
          "harness/providers/anthropic",
          "harness/providers/openai",
          "harness/providers/gemini",
          "harness/providers/local"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "deeda.com",
        "href": "https://www.deeda.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get deeda Think",
      "href": "https://www.deeda.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/deeda"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "mcp"]
  }
}
